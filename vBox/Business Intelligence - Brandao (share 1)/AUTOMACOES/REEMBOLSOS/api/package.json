{
  "name": "reembolsos-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute reembolsos --file=../migrations/001_initial.sql",
    "db:migrate:prod": "wrangler d1 execute reembolsos --file=../migrations/001_initial.sql --remote",
    "db:seed": "node ../scripts/seed.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240718.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.65.0"
  }
}
