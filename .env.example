# ============================================================
# .env.example — copie para .env e preencha os valores reais
# O arquivo .env NÃO deve ser commitado no GitHub (.gitignore)
# ============================================================

# ── Cloudflare D1 ───────────────────────────────────────────
# Onde encontrar:
#   CF_ACCOUNT_ID:     painel.cloudflare.com > lado direito da tela inicial
#   CF_D1_DATABASE_ID: Workers & Pages > D1 > seu banco > Settings
#   CF_API_TOKEN:      Meu Perfil > API Tokens > Create Token
#                      Permissão: D1:Edit (ou Account > D1 > Edit)
CF_ACCOUNT_ID=seu_account_id_aqui
CF_API_KEY=sua_global_api_key_aqui
CF_API_EMAIL=seu_email@gmail.com
CF_D1_DATABASE_ID=seu_database_id_aqui

# ── SMTP (só necessário para execução local com modo smtp) ──
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=relatorio@nobelcapital.com.br
# SMTP_PASSWORD=sua_senha_aqui
# SMTP_FROM=relatorio@nobelcapital.com.br
